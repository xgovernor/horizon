<div
  id="status-bar"
  class="bg-nvim-statusline text-nvim-fg h-6 flex items-center justify-between text-xs font-bold uppercase tracking-tight"
>
  <div class="flex items-center">
    <div
      id="mode"
      class="px-2 bg-nvim-green text-nvim-bg transition-colors duration-150 mr-2"
    >
      NORMAL
    </div>
    <div id="command-line" class="font-normal lowercase"></div>
  </div>
  <div class="flex items-center gap-4">
    <div id="file-info" class="font-normal">HORIZON</div>
    <div id="position" class="bg-nvim-gray px-2">1:1</div>
  </div>
</div>

<script>
  import { store, subscribe } from "../scripts/store.ts";
  import type { StoreState } from "../scripts/store.ts";

  const MODE_COLORS: Record<string, string> = {
    NORMAL: "bg-nvim-green",
    INSERT: "bg-nvim-blue",
    VISUAL: "bg-nvim-orange",
    COMMAND: "bg-nvim-yellow",
    SEARCH: "bg-nvim-red",
  };

  // Module-level unsub — survives between initStatusBar calls so we can
  // clean up the previous subscription before creating a new one.
  let unsub: (() => void) | null = null;

  function initStatusBar() {
    // FIX: clean up previous subscription before re-subscribing.
    // Without this, every page transition stacks another subscriber.
    unsub?.();

    const el = {
      mode: document.getElementById("mode")!,
      commandLine: document.getElementById("command-line")!,
      fileInfo: document.getElementById("file-info")!,
      position: document.getElementById("position")!,
    };

    function applyState(patch: Partial<StoreState>): void {
      const { mode, commandLine, fileInfo, position } = patch;

      if (mode !== undefined) {
        el.mode.textContent = mode;
        // Reset all color classes then apply the correct one
        el.mode.className =
          "px-2 transition-colors duration-150 mr-2 text-nvim-bg";
        el.mode.classList.add(MODE_COLORS[mode] ?? "bg-nvim-gray");
      }
      if (commandLine !== undefined) el.commandLine.textContent = commandLine;
      if (fileInfo !== undefined) el.fileInfo.textContent = fileInfo;
      if (position !== undefined) el.position.textContent = position;
    }

    // Hydrate from current store state immediately — no missed-event risk
    applyState(store as Partial<StoreState>);

    // Subscribe to future changes — only re-renders what actually changed
    unsub = subscribe((state, changed) => {
      const patch: Partial<StoreState> = {};
      for (const key of changed) {
        // Safe: key is always keyof StoreState here
        (patch as Record<string, unknown>)[key] = state[key];
      }
      applyState(patch);
    });
  }

  // FIX: call directly on first load — astro:page-load only fires on
  // subsequent View Transition navigations, not on the initial page load
  // if View Transitions aren't enabled (or before they kick in).
  initStatusBar();

  // Re-init after each client-side page swap so DOM refs stay fresh
  document.addEventListener("astro:page-load", initStatusBar);
</script>
