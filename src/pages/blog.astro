---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const blogPosts = await getCollection("blog");
blogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog">
  <ul id="blog-list">
    {
      blogPosts.map((post, index) => (
        <li
          class="mb-3 grid grid-cols-[2fr_3fr_1fr] gap-4 items-start blog-item"
          data-index={index}
          data-href={`/blog/${post.id}`}
        >
          <a
            href={`/blog/${post.id}`}
            class="text-nvim-blue text-[15px] hover:underline font-semibold"
          >
            {post.data.title}
          </a>
          <p class="text-gray-600 text-sm line-clamp-3">{post.data.summary}</p>
          <time
            datetime={post.data.date.toISOString()}
            class="text-gray-500 text-sm"
          >
            {post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </time>
        </li>
      ))
    }
  </ul>
</Layout>

<style>
  @reference "../styles/global.css";

  .blog-item {
    @apply p-2 transition-all duration-200 ease-in-out cursor-pointer;
  }

  .blog-item.active {
    @apply border-l-4 pl-3;
    background-color: color-mix(in srgb, var(--color-nvim-blue) 20%, transparent);
    border-color: var(--color-nvim-blue);
  }

  /* Vim-style cursor indicator */
  .blog-item.active::before {
    content: ">";
    @apply font-bold absolute -ml-6;
    color: var(--color-nvim-blue);
  }
</style>

<script>
  let currentIndex = 0;
  const blogItems = document.querySelectorAll(".blog-item");

  function updateActiveBlogItem() {
    blogItems.forEach((item, index) => {
      if (index === currentIndex) {
        item.classList.add("active");
        item.scrollIntoView({ behavior: "smooth", block: "nearest" });
      } else {
        item.classList.remove("active");
      }
    });
  }

  function moveCursor(direction: number) {
    currentIndex += direction;
    if (currentIndex < 0) currentIndex = blogItems.length - 1;
    if (currentIndex >= blogItems.length) currentIndex = 0;
    updateActiveBlogItem();
  }

  function enterBlogPost() {
    const activeItem = document.querySelector(".blog-item.active");
    if (activeItem) {
      window.location.href = activeItem.getAttribute("data-href") ?? "";
    }
  }

  document.addEventListener("keydown", (e) => {
    if (["j", "k", "Enter"].includes(e.key)) {
      e.preventDefault();
    }

    switch (e.key) {
      case "j": // Move down
        moveCursor(1);
        break;
      case "k": // Move up
        moveCursor(-1);
        break;
      case "g": // Go to first item
        currentIndex = 0;
        updateActiveBlogItem();
        break;
      case "G": // Go to last item
        currentIndex = blogItems.length - 1;
        updateActiveBlogItem();
        break;
      case "Enter": // Select current item
      case "l": // Vim-like right movement to enter
        enterBlogPost();
        break;
    }
  });

  // Initialize the first item as active
  updateActiveBlogItem();

  // Allow click selection as well
  blogItems.forEach((item, index) => {
    item.addEventListener("click", (e) => {
      // Only handle the click on the li element
      if (e.currentTarget === e.target) {
        currentIndex = index;
        updateActiveBlogItem();
      }
    });
  });
</script>
